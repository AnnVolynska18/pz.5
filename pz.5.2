using System;
using System.Drawing;
using System.Windows.Forms;

namespace WindowsFormsApp
{
    public class MainForm : Form
    {
        private ToolStrip toolStrip1;
        private RichTextBox richTextBox1;

        public MainForm()
        {
            // 1. Налаштування форми
            this.Text = "Текстовий редактор зі спливаючими підказками";
            this.Size = new Size(600, 400);
            this.StartPosition = FormStartPosition.CenterScreen;

            // 2. Ініціалізація та налаштування RichTextBox
            richTextBox1 = new RichTextBox();
            richTextBox1.Dock = DockStyle.Fill;
            richTextBox1.Font = new Font("Arial", 12f);
            richTextBox1.Name = "richTextBox1";

            // 3. Ініціалізація ToolStrip та увімкнення підказок
            toolStrip1 = new ToolStrip();
            toolStrip1.Name = "toolStrip1";
            toolStrip1.ShowItemToolTips = true; // Дозволяє відображення підказок для елементів

            // 4. Створення кнопок для ToolStrip
            ToolStripButton btnNew = new ToolStripButton("Створити");
            ToolStripButton btnCut = new ToolStripButton("Вирізати");
            ToolStripButton btnCopy = new ToolStripButton("Копіювати");
            ToolStripButton btnPaste = new ToolStripButton("Вставити");

            // ==========================================
            // НАЛАШТУВАННЯ СПЛИВАЮЧИХ ПІДКАЗОК (ToolTipText)
            // ==========================================
            btnNew.ToolTipText = "Створити новий документ (очистити поле)";
            btnCut.ToolTipText = "Вирізати виділений текст у буфер обміну";
            btnCopy.ToolTipText = "Копіювати виділений текст у буфер обміну";
            btnPaste.ToolTipText = "Вставити текст із буфера обміну";
            // ==========================================

            // 5. Додавання обробників подій (логіки) для кнопок
            btnNew.Click += (sender, e) => richTextBox1.Clear();
            btnCut.Click += (sender, e) => richTextBox1.Cut();
            btnCopy.Click += (sender, e) => richTextBox1.Copy();
            btnPaste.Click += (sender, e) => richTextBox1.Paste();

            // 6. Додавання елементів на панель інструментів
            toolStrip1.Items.Add(btnNew);
            toolStrip1.Items.Add(new ToolStripSeparator()); // Розділювач
            toolStrip1.Items.Add(btnCut);
            toolStrip1.Items.Add(btnCopy);
            toolStrip1.Items.Add(btnPaste);

            // 7. Додавання компонентів на форму
            this.Controls.Add(richTextBox1);
            this.Controls.Add(toolStrip1);
        }
    }

    public static class Program
    {
        [STAThread]
        public static void Main()
        {
            Application.EnableVisualStyles();
            Application.SetCompatibleTextRenderingDefault(false);
            Application.Run(new MainForm());
        }
    }
}
